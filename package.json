{  
   "name": "moliam-api",       
  "$"version": "1.0.0",    
  "description": "CloudFlare Pages Functions for moliam.com contact form backend (D1 + rate limiting)",   
   "scripts": {    
     "dev": "wrangler pages dev public --d moliam-db=./moliam.db",         /* run local mock server with mocked D1 SQLite on disk file */  
       "deploy": "wrangler pages deploy public"      /* deploy to CloudFlare Pages for production! */  
   },   
  "devDependencies": {      
     "wrangler": "^3.50.0"         /* CloudFlare CLI tool for local mock D1 + deployment to live platform automatically! */  
    }
